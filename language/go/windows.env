# Golang 环境配置
# filepath: ~\AppData\Roaming\go\env

# 碎文件转移到 DevDrive 上
GOPATH=G:\AppData\go
GOCACHE=G:\AppData\go-build
GOMODCACHE=G:\AppData\go\pkg\mod
# 但安装的包还是放在 C 盘
GOBIN=C:\Users\enihsyou\AppData\Local\go\bin

# 不给 GOPROXY 添加 ",direct"，避免找不到时回退到难以访问的源站

# 官方全球代理
# GOPROXY=https://proxy.golang.com.cn
# 阿里云
# GOPROXY=https://mirrors.aliyun.com/goproxy/
# 七牛云
GOPROXY=https://goproxy.cn
GOSUMDB=sum.golang.google.cn

# Benchmark 测试方法
# 1. go clean -modcache                                # 清空本地缓存
# 2. Measure-Command { go get -x github.com/apex/log } # 验证下载速度
# 3. Measure-Command { go get -x github.com/apex/log } # 验证拉取速度
# 测试结果  Download SyncUpdate
# - 官方    5212ms   1174ms
# - 阿里云  2076ms   1344ms
# - 七牛云  1004ms    284ms
